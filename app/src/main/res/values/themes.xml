<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.TVBox_Tools" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryDark">@color/cyber_dark</item>
        <item name="colorAccent">@color/neon_magenta</item>
        <item name="android:windowBackground">@color/cyber_dark</item>
        <item name="android:statusBarColor">@color/cyber_dark</item>
    </style>

    <style name="Theme.TVBox_Tools" parent="Base.Theme.TVBox_Tools">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryDark">@color/cyber_dark</item>
        <item name="colorAccent">@color/neon_magenta</item>
        <item name="android:windowBackground">@color/gradient_start</item>
    </style>

    <!-- 圆角按钮样式 -->
    <style name="RoundedButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">20dp</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="backgroundTint">@color/button_primary</item>
        <item name="android:elevation">4dp</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardStyle">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>
</resources>