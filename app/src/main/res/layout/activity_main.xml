<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/coordinator_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/cyber_gradient_bg">

    <!-- 主内容区域 -->
    <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

            <!-- WebView 容器 -->
            <androidx.cardview.widget.CardView
                    android:id="@+id/web_view_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="80dp"
                    android:layout_marginBottom="100dp"
                    android:layout_marginHorizontal="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="20dp"
                    app:cardBackgroundColor="#0D0D0D"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/neon_cyan">

                <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    <WebView
                            android:id="@+id/web_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="visible"/>

                    <!-- 加载动画覆盖层 -->
                    <ProgressBar
                            android:id="@+id/progress_bar"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/neon_cyan"
                            android:visibility="gone"/>

                    <!-- Cookie过期时间小标签 -->
                    <TextView
                            android:id="@+id/tv_cookie_expires"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:layout_marginBottom="4dp"
                            android:layout_marginEnd="4dp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:textSize="10sp"
                            android:textColor="#CCFFFFFF"
                            android:background="#20000000"
                            android:visibility="gone"
                            android:maxEms="20"
                            android:ellipsize="end"
                            android:singleLine="true"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- 服务列表面板 -->
            <androidx.cardview.widget.CardView
                    android:id="@+id/service_panel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="80dp"
                    android:layout_marginBottom="100dp"
                    android:layout_marginHorizontal="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="20dp"
                    app:cardBackgroundColor="#1A1A2E"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/neon_magenta"
                    android:visibility="gone">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                    <!-- 面板标题 -->
                    <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="选择服务"
                            android:textSize="24sp"
                            android:textColor="@color/neon_cyan"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="20dp"
                            android:background="@drawable/glass_header_bg"/>

                    <!-- 服务列表 -->
                    <ListView
                            android:id="@+id/service_list"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:divider="@drawable/neon_divider"
                            android:dividerHeight="1dp"
                            android:padding="12dp"
                            android:clipToPadding="false"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 顶部标题栏 - 毛玻璃效果 -->
    <androidx.cardview.widget.CardView
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_margin="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#1A1A2ECC">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

            <!-- 菜单按钮 -->
            <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_menu"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:icon="@drawable/ic_menu"
                    app:iconTint="@color/neon_cyan"
                    app:iconSize="28dp"
                    android:background="@drawable/glow_button_cyan"/>

            <!-- 标题 -->
            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TVBox Tools"
                    android:textSize="22sp"
                    android:textColor="@color/neon_cyan"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:shadowColor="@color/neon_cyan"
                    android:shadowRadius="10"
                    android:shadowDx="0"
                    android:shadowDy="0"/>

            <!-- 获取认证按钮 -->
            <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_auth"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:icon="@drawable/ic_key"
                    app:iconTint="@color/neon_magenta"
                    app:iconSize="28dp"
                    android:background="@drawable/glow_button_magenta"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 底部弧形导航栏 -->
    <androidx.cardview.widget.CardView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_gravity="bottom"
            android:layout_margin="12dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="15dp"
            app:cardBackgroundColor="#1A1A2ECC">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="8dp">

            <!-- 后退按钮 -->
            <LinearLayout
                    android:id="@+id/btn_back"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/nav_item_selector"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_back"
                        app:tint="@color/neon_cyan"
                        android:contentDescription="@string/btn_back"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_back"
                        android:textSize="11sp"
                        android:textColor="@color/neon_cyan"
                        android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- 刷新按钮 -->
            <LinearLayout
                    android:id="@+id/btn_refresh"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/nav_item_selector"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_refresh"
                        app:tint="@color/neon_magenta"
                        android:contentDescription="@string/btn_refresh"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_refresh"
                        android:textSize="11sp"
                        android:textColor="@color/neon_magenta"
                        android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- 中央大按钮 - 服务列表 -->
            <FrameLayout
                    android:id="@+id/btn_service_center"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/fab_glow_background"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_list"
                        app:tint="@color/white"
                        android:contentDescription="@string/btn_select_list"/>
            </FrameLayout>

            <!-- 前进按钮 -->
            <LinearLayout
                    android:id="@+id/btn_forward"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/nav_item_selector"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_forward"
                        app:tint="@color/neon_purple"
                        android:contentDescription="@string/btn_forward"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_forward"
                        android:textSize="11sp"
                        android:textColor="@color/neon_purple"
                        android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- 清除按钮 -->
            <LinearLayout
                    android:id="@+id/btn_reset"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/nav_item_selector"
                    android:clickable="true"
                    android:focusable="true">

                <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        app:tint="@color/neon_pink"
                        android:contentDescription="@string/btn_reset"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_reset"
                        android:textSize="11sp"
                        android:textColor="@color/neon_pink"
                        android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>