<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
        android:color="#3000FFFF">
    <item>
        <layer-list>
            <!-- 外发光效果 -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#2000FFFF"/>
                    <size android:width="52dp" android:height="52dp"/>
                </shape>
            </item>
            <!-- 主按钮 -->
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="oval">
                    <solid android:color="#1A1A2E"/>
                    <stroke android:width="2dp" android:color="#00FFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>