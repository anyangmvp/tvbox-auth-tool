<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最外层发光 -->
    <item>
        <shape android:shape="oval">
            <gradient
                    android:angle="135"
                    android:startColor="#40FF00FF"
                    android:centerColor="#4000FFFF"
                    android:endColor="#409D00FF"
                    android:type="linear"/>
            <size android:width="76dp" android:height="76dp"/>
        </shape>
    </item>
    <!-- 中层发光 -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                    android:angle="135"
                    android:startColor="#60FF00FF"
                    android:centerColor="#6000FFFF"
                    android:endColor="#609D00FF"
                    android:type="linear"/>
        </shape>
    </item>
    <!-- 主按钮 -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                    android:angle="135"
                    android:startColor="#FF00FF"
                    android:centerColor="#00FFFF"
                    android:endColor="#9D00FF"
                    android:type="linear"/>
            <stroke android:width="2dp" android:color="#FFFFFF"/>
        </shape>
    </item>
</layer-list>